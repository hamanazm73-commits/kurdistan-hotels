rules_version = '2';

// ============================================================
//  Firebase Storage rules — Kurdistan Hotels
//  Deploy: Firebase console > Storage > Rules > paste > Publish
//
//  Hotel media: anyone can VIEW; only signed-in owner/admin/hotel
//  accounts can UPLOAD images or videos (up to 200 MB each).
// ============================================================

service firebase.storage {
  match /b/{bucket}/o {
    match /hotels/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 200 * 1024 * 1024         // max 200 MB
        && (
          request.resource.contentType.matches('image/.*')
          || request.resource.contentType.matches('video/.*')
        );
    }
  }
}
