rules_version = '2';

// Deploy: Firebase console > Firestore > Rules > paste > Publish.
// Set ownerEmail() to your login email (lowercase).

service cloud.firestore {
  match /databases/{database}/documents {

    function ownerEmail() {
      return "hamanazm73@gmail.com"; // owner / super-admin
    }
    function isSignedIn() {
      return request.auth != null;
    }
    function emailLower() {
      return request.auth.token.email.lower();
    }
    function isOwner() {
      return isSignedIn() && emailLower() == ownerEmail();
    }
    function hasRole() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/roles/$(emailLower()));
    }
    function myRole() {
      return get(/databases/$(database)/documents/roles/$(emailLower())).data;
    }
    function isAdmin() {
      return isOwner() ||
        (hasRole() && myRole().enabled == true
          && (myRole().role == 'admin' || myRole().role == 'owner'));
    }

    // Hotels: anyone can read; only owner/admins can change.
    match /hotels/{id} {
      allow read: if true;
      allow create, delete: if isAdmin();
      // owner/admins edit any hotel; a hotel owner edits only their own,
      // and may NOT change featured / recommended / discount.
      allow update: if isAdmin() ||
        (hasRole() && myRole().enabled == true && myRole().role == 'hotel'
          && myRole().hotelId == id
          // a hotel owner can't touch a hotel the admin has hidden,
          // and can't change the hidden flag themselves
          && resource.data.get('hidden', false) != true
          && request.resource.data.get('hidden', false) == resource.data.get('hidden', false)
          && request.resource.data.featured == resource.data.featured
          && request.resource.data.recommended == resource.data.recommended
          && request.resource.data.discount.active == resource.data.discount.active
          && request.resource.data.discount.oldPrice == resource.data.discount.oldPrice
          && request.resource.data.discount.newPrice == resource.data.discount.newPrice);
    }

    // Hotel gallery + inline video, split off the hotel doc to keep the public
    // hotel list light. Anyone can read; owner/admins write any, a hotel owner
    // writes only their own hotel's media.
    match /hotelMedia/{id} {
      allow read: if true;
      allow write: if isAdmin() ||
        (hasRole() && myRole().enabled == true && myRole().role == 'hotel'
          && myRole().hotelId == id);
    }

    // Bookings: created server-side via the API (Admin SDK). Owner/admins
    // read all; a hotel owner reads only bookings for their own hotel.
    match /bookings/{id} {
      allow read: if isAdmin() ||
        (hasRole() && myRole().enabled == true && myRole().role == 'hotel'
          && resource.data.hotelId == myRole().hotelId);
      allow write: if false;
    }

    // Global settings (e.g. the market USD rate): anyone can read; owner/admins write.
    match /settings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Roles: a user may read their own role; only the owner manages roles.
    match /roles/{email} {
      allow get: if isOwner() || (isSignedIn() && emailLower() == email);
      allow list: if isOwner();
      allow create, update, delete: if isOwner();
    }
  }
}
