rules_version = '2';

// ============================================================
//  Kurdistan Hotels — Firestore security rules
//
//  Deploy:  copy into Firebase console > Firestore > Rules,
//  OR run:  firebase deploy --only firestore:rules
//
//  IMPORTANT: set OWNER_EMAIL below to the SAME email you put in
//  NEXT_PUBLIC_OWNER_EMAIL in .env.local (lowercase).
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function ownerEmail() {
      return "hamanazm73@gmail.com"; // owner / super-admin
    }
    function isSignedIn() {
      return request.auth != null;
    }
    function emailLower() {
      return request.auth.token.email.lower();
    }
    function isOwner() {
      return isSignedIn() && emailLower() == ownerEmail();
    }
    function isAdmin() {
      return isOwner() ||
        (isSignedIn()
          && exists(/databases/$(database)/documents/roles/$(emailLower()))
          && get(/databases/$(database)/documents/roles/$(emailLower())).data.enabled == true);
    }

    // Hotels: anyone can read; only owner/admins can change.
    match /hotels/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Bookings: created server-side via the rate-limited API (Admin SDK),
    // so clients can't write directly. Only admins can read them.
    match /bookings/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Roles: a user may read their own role; only the owner manages roles.
    match /roles/{email} {
      allow get: if isOwner() || (isSignedIn() && emailLower() == email);
      allow list: if isOwner();
      allow create, update, delete: if isOwner();
    }
  }
}
